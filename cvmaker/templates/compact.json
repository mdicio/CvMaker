{
    "fonts": {
        "name": "Calibri",
        "heading1_size": 18,
        "heading2_size": 11,
        "heading3_size": 10,
        "body_size": 9
    },
    "colors": {
        "heading": "#2c3e50",
        "subheading": "#34495e",
        "body": "#333333",
        "accent": "#3498db"
    },
    "spacing": {
        "section_before": 6,
        "section_after": 3,
